# Telegram bot tokenini @BotFather dan oling: /newbot yoki /revoke
TELEGRAM_BOT_TOKEN=

# Kanal username (@ bilan) yoki chat_id
TELEGRAM_CHANNEL=@realyangilik

# Gemini API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --once rejimi uchun: har necha daqiqada tekshirish
POLL_INTERVAL_MINUTES=15

# --rotate rejimi uchun: har necha daqiqada 1 ta yangilik chiqarish
POST_INTERVAL_MINUTES=35

# SQLite fayl yo'li
DB_PATH=news.db
